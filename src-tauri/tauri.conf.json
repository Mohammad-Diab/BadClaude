{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BadClaude",
  "version": "2.0.0",
  "identifier": "com.mohammad-diab.badclaude",
  "build": {
    "frontendDist": "../web"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico",
      "icons/icon.icns",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ]
  }
}
